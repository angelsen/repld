---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
	title="Blog — repld"
	description="Notes on building repld — positioning, design decisions, and where the gist/controls/production model is headed."
	active="blog"
>
	<!-- ==================== hero ==================== -->
	<section class="hero">
		<p class="tag">notes</p>
		<h1 class="display">Blog</h1>
		<p class="hero-sub">Positioning, design decisions, and where repld is headed.</p>
	</section>

	<!-- ==================== post list ==================== -->
	<Section label="posts">
		<div class="post-list" data-reveal>
			{
				posts.map((post) => (
					<a class="post-card" href={`${base}blog/${post.id}`}>
						<div class="post-meta">
							<time datetime={post.data.pubDate.toISOString()}>
								{dateFmt.format(post.data.pubDate)}
							</time>
							{post.data.tags.length > 0 && (
								<span class="post-tags">{post.data.tags.join(' · ')}</span>
							)}
						</div>
						<h2>{post.data.title}</h2>
						<p>{post.data.description}</p>
					</a>
				))
			}
		</div>
	</Section>
</BaseLayout>

<style>
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}
	.post-card {
		display: block;
		border: 1px solid var(--color-line);
		background: var(--color-panel);
		border-radius: 10px;
		padding: 24px 26px;
		text-decoration: none;
		transition:
			border-color 0.2s,
			transform 0.2s;
	}
	.post-card:hover {
		border-color: var(--accent-glow);
		transform: translateY(-2px);
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 10px;
		font-size: 12px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-muted);
	}
	.post-tags {
		color: var(--color-accent);
	}
	.post-card h2 {
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--color-bright);
		font-size: 20px;
		margin-bottom: 10px;
		line-height: 1.3;
	}
	.post-card p {
		color: var(--color-muted);
		font-size: 14px;
		line-height: 1.7;
		max-width: 70ch;
	}

	@media (max-width: 560px) {
		.post-card {
			padding: 20px;
		}
	}
</style>
