---
import { Icon } from '@astrojs/starlight/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import CodeCard from '../components/CodeCard.astro';
import NudgeCard from '../components/NudgeCard.astro';

const twoLayerCore = `"""acme — client for the Acme directory."""

import os
import httpx

# --- core logic (portable — keeps on graduation) ---

async def lookup(company_id: str) -> dict:
    """Look up a company. -> {name, address, ...}"""
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const twoLayerWiring = `# --- repld wiring (shed on graduation) ---

__repld_tools__ = [
    {"name": "lookup", "description": "Look up a company",
     "inputSchema": {"type": "object",
                     "properties": {"company_id": {"type": "string"}},
                     "required": ["company_id"]}},
]

async def _tool_lookup(args: dict) -> str:
    import json
    result = await lookup(args["company_id"])
    return json.dumps(result)`;

const fetchPattern = `# Browser-auth variant — accept a fetch callable
# Works with browser session (no token) AND standalone (token from env)

async def lookup(company_id: str, *, fetch=None) -> dict:
    """Look up a company. -> {name, address, ...}"""
    if fetch is not None:
        return (await fetch(f"/api/company/{company_id}"))["body"]
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const envSnippet = `# .env at project root — loaded by repld at boot,
# by FastAPI/FastMCP in production. Same file, both contexts.

API_TOKEN=sk-live-abc123
ACME_API_KEY=xyz789
DATABASE_URL=postgresql://localhost/mydb`;

const fastmcpSnippet = `from fastmcp import FastMCP
from gists.acme import lookup

mcp = FastMCP("my-service")

# One line — schema generated from type hints + docstring
mcp.add_tool(lookup)`;

const fastmcpDecoratorSnippet = `# When you need a different name or adapted parameters:
@mcp.tool
async def company_lookup(company_id: str) -> dict:
    """Look up a company."""
    return await lookup(company_id)`;

const fastapiSnippet = `from fastapi import APIRouter
from gists.acme import lookup

router = APIRouter()

@router.get("/company/{company_id}")
async def company_lookup(company_id: str):
    return await lookup(company_id)`;

const scaffoldSnippet = `$ uv init my-service && cd my-service

# Add framework
$ uv add fastmcp                # or: uv add fastapi uvicorn

# Add gist deps (from __repld_deps__)
$ uv add httpx

# If browser-backed:
$ uv add repld-tool[browser]

# Copy gists (vendor them)
$ mkdir -p gists
$ cp ~/other-project/gists/acme.py gists/

# Run
$ uv run fastmcp run server.py  # FastMCP
$ uv run uvicorn main:app       # FastAPI`;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout
	title="Production — graduate a gist to a running service"
	description="The Python Claude wrote during prototyping runs in production unchanged. Wrap it in FastMCP or FastAPI and swap the few lines that connect it."
	active="production"
>
	<!-- ==================== hero ==================== -->
	<section class="hero">
		<p class="tag">production</p>
		<h1 class="display">From gist<br />to service.</h1>
		<p class="hero-sub">
			A gist is a plain Python file. The same file runs in repld while you and Claude prototype,
			then in FastMCP or FastAPI once it ships. You swap the few lines that connect it. This page
			shows how.
		</p>
	</section>

	<!-- ==================== two-layer pattern ==================== -->
	<Section label="the two-layer pattern">
		<h2 class="display sm">Core logic stays.<br />Wiring gets replaced.</h2>
		<p class="body-text">
			Write gists in two layers. The core logic sits at the top and moves to production untouched.
			The repld wiring sits at the bottom: <code class="c">__repld_tools__</code> and
			<code class="c">_tool_*</code>. That bottom layer drops away when the gist graduates, and a
			<code class="c">@mcp.tool</code> or <code class="c">@router.get</code> takes its place.
		</p>
		<div class="code-stack" data-reveal>
			<CodeCard code={twoLayerCore} label="keeps" labelTone="accent" class="keeps" />
			<div class="seam" aria-hidden="true">
				<span class="seam-label">graduation line</span>
			</div>
			<CodeCard code={twoLayerWiring} label="sheds" labelTone="dim" class="sheds" />
		</div>
	</Section>

	<!-- ==================== fetch callable ==================== -->
	<Section label="browser auth portability">
		<div class="split">
			<div>
				<h2 class="display sm">The browser is the credential.</h2>
				<p class="body-text">
					Some APIs only authenticate through your logged-in browser session, with no API key to
					hand out. For those, accept a <code class="c">fetch=</code> callable. In repld you pass
					<code class="c">tab.fetch</code>, which rides your live session. In production you pass an
					httpx client or switch to a token. The core function reads the same data either way.
				</p>
			</div>
			<CodeCard code={fetchPattern} />
		</div>
	</Section>

	<!-- ==================== secrets / .env ==================== -->
	<Section label="secrets">
		<div class="split">
			<div>
				<h2 class="display sm">One <code class="c">.env</code>,<br />both contexts.</h2>
				<p class="body-text">
					Core logic reads tokens from <code class="c">os.environ</code>, so nothing is hardcoded.
					repld loads <code class="c">.env</code> from the project root when the session starts. Your
					production framework loads the same file its own way. The gist code stays identical.
				</p>
			</div>
			<CodeCard code={envSnippet} lang="bash" />
		</div>
	</Section>

	<!-- ==================== three tiers ==================== -->
	<Section label="graduation tiers">
		<h2 class="display sm">Pick the tier that fits.</h2>
		<p class="body-text">
			Gists don't all need the same production setup. Some hit public APIs with a token. Others need
			your browser's authenticated session. A few want both.
		</p>
		<div class="table-wrap" data-reveal>
			<table>
				<thead>
					<tr>
						<th>Tier</th>
						<th>Auth</th>
						<th>repld dep?</th>
						<th>When</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td class="lname">Standalone</td>
						<td><code class="c">.env</code> tokens</td>
						<td>No</td>
						<td>Stable API, you have keys</td>
					</tr>
					<tr>
						<td class="lname">Browser-backed</td>
						<td><code class="c">browser.fetch()</code></td>
						<td><code class="c">repld-tool[browser]</code></td>
						<td>Session-auth APIs, no proper keys</td>
					</tr>
					<tr>
						<td class="lname">Hybrid</td>
						<td>Token + browser fallback</td>
						<td>Optional</td>
						<td>Token when available, browser otherwise</td>
					</tr>
				</tbody>
			</table>
		</div>
	</Section>

	<!-- ==================== fastmcp ==================== -->
	<Section label="fastmcp">
		<div class="split">
			<div>
				<h2 class="display sm">One line to<br />an MCP tool.</h2>
				<p class="body-text">
					<code class="c">mcp.add_tool()</code> reads the input schema off your type hints and the description
					off the docstring. If the core function's signature already fits, that one line is the whole
					integration.
				</p>
			</div>
			<div class="code-stack-sm" data-reveal>
				<CodeCard code={fastmcpSnippet} />
				<CodeCard code={fastmcpDecoratorSnippet} />
			</div>
		</div>
	</Section>

	<!-- ==================== fastapi ==================== -->
	<Section label="fastapi">
		<div class="split">
			<div>
				<h2 class="display sm">Same function,<br />HTTP endpoint.</h2>
				<p class="body-text">
					Wrap the core function in a route decorator and FastAPI takes it from there: request
					validation, JSON serialization, OpenAPI docs. The gist itself doesn't change.
				</p>
			</div>
			<CodeCard code={fastapiSnippet} />
		</div>
	</Section>

	<!-- ==================== scaffolding ==================== -->
	<Section label="scaffolding">
		<h2 class="display sm">Seven commands to a running service.</h2>
		<p class="body-text">
			Create a project, add the dependencies, copy the gist in, run it. The
			<code class="c">__repld_tools__</code> layer stays behind. A <code class="c">@mcp.tool</code> or
			<code class="c">@router.get</code> replaces it.
		</p>
		<CodeCard code={scaffoldSnippet} lang="bash" class="wide" />
	</Section>

	<!-- ==================== what stays / what goes ==================== -->
	<Section label="what stays, what goes">
		<h2 class="display sm">What moves, what stays put.</h2>
		<div class="compare" data-reveal>
			<div class="compare-col stays">
				<h3 class="compare-head accent">Stays <span class="dim">(portable)</span></h3>
				<ul>
					<li>Core async functions</li>
					<li>Type hints + docstrings</li>
					<li><code class="c">os.environ["TOKEN"]</code></li>
					<li>Data parsing helpers</li>
					<li><code class="c">__repld_deps__</code> <span class="dim">(as reference)</span></li>
				</ul>
			</div>
			<div class="compare-col goes">
				<h3 class="compare-head">Goes <span class="dim">(repld-specific)</span></h3>
				<ul>
					<li><code class="c">__repld_tools__</code> list</li>
					<li><code class="c">_tool_*</code> handler functions</li>
					<li><code class="c">import repld</code> <span class="dim">(in wiring)</span></li>
					<li><code class="c">tab.fetch</code> / <code class="c">browser.get</code></li>
					<li><code class="c">__repld_usage__</code></li>
				</ul>
			</div>
		</div>
	</Section>

	<!-- ==================== nudge claude ==================== -->
	<Section label="nudge claude">
		<h2 class="display sm">Say this when you're ready.</h2>
		<p class="body-text">
			Claude reads the production guide on demand. One line gives it the context for the whole
			graduation conversation.
		</p>
		<div class="nudge-grid" data-reveal>
			<NudgeCard
				when="Starting the conversation"
				say="Read repld://docs/production — let's graduate this gist"
			/>
			<NudgeCard
				when="Standalone service"
				say="Set up a FastMCP server for this gist — no browser needed"
			/>
			<NudgeCard
				when="Browser-backed service"
				say="Graduate this to FastAPI with repld-tool[browser]"
			/>
		</div>
	</Section>

	<!-- ==================== outro ==================== -->
	<section class="outro" data-anim>
		<blockquote data-reveal>
			The same file carries you from discovery to production. You and Claude prototype live: poking
			at APIs, reverse-engineering the traffic, shaping the data into clean Python. Once it works,
			you copy the file, swap the few lines that connect it, and run it headless. Nothing gets
			rewritten. The progression doesn't stop at the REPL. It ends at a running service.
		</blockquote>
		<div class="back-links" data-reveal>
			<a href={`${base}playbook`}><Icon name="left-arrow" size="1em" /> the playbook</a>
			<a href={`${base}quickstart`}>quickstart <Icon name="right-arrow" size="1em" /></a>
		</div>
	</section>
</BaseLayout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);
	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!reduced) {
		// Tier rows light up their left edge as they enter.
		gsap.utils.toArray<HTMLElement>('tbody tr').forEach((row) => {
			gsap.from(row, {
				autoAlpha: 0,
				x: -16,
				duration: 0.5,
				ease: 'power2.out',
				scrollTrigger: { trigger: row, start: 'top 90%' },
			});
		});
	}
</script>

<style>
	/* code stacks — page-specific composition of shared cards */
	.code-stack {
		display: flex;
		flex-direction: column;
	}
	.code-stack :global(.code-card.keeps) {
		border-bottom-left-radius: 0;
		border-bottom-right-radius: 0;
		border-bottom: none;
		border-color: var(--accent-line);
	}
	/* sheds — amber caution treatment on the whole disposable block */
	.code-stack :global(.code-card.sheds) {
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		border-top: none;
		border-color: rgb(255 180 84 / 0.25);
		background:
			repeating-linear-gradient(45deg, rgb(255 180 84 / 0.06) 0 1px, transparent 1px 10px),
			var(--color-panel-2);
	}

	/* the graduation seam — a thin amber line between keeps & sheds */
	.seam {
		position: relative;
		height: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		border-top: 1px solid rgb(255 180 84 / 0.35);
		border-left: 1px solid var(--color-line);
		border-right: 1px solid var(--color-line);
	}
	.seam-label {
		position: absolute;
		z-index: 1;
		background: var(--color-ink);
		color: var(--color-amber);
		font-size: 10px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		padding: 4px 14px;
		border: 1px solid rgb(255 180 84 / 0.35);
		border-radius: 999px;
	}
	.code-stack-sm {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	:global(.code-card.wide) {
		max-width: 680px;
	}

	/* tier table — accent on hover */
	.lname {
		border-left: 2px solid transparent;
		padding-left: 12px;
		margin-left: -14px;
		transition: border-color 0.2s;
	}
	tbody tr:hover .lname {
		border-color: var(--color-accent);
	}

	/* comparison */
	.compare {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 16px;
		max-width: 720px;
	}
	.compare-col {
		border: 1px solid var(--color-line);
		border-radius: 10px;
		padding: 24px 22px;
		background: var(--color-panel);
	}
	.compare-col.stays {
		border-color: rgb(60 232 130 / 0.25);
	}
	.compare-head {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 14px;
		margin-bottom: 16px;
		color: var(--color-bright);
	}
	.compare-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.compare-col li {
		color: var(--color-fg);
		font-size: 13.5px;
		padding-left: 16px;
		position: relative;
	}
	.compare-col li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 8px;
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}
	.stays li::before {
		background: var(--color-accent);
	}
	.goes li::before {
		background: var(--color-muted);
		opacity: 0.5;
	}

	@media (max-width: 900px) {
		.compare {
			grid-template-columns: minmax(0, 1fr);
		}
	}
</style>
