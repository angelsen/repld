---
import { Icon } from '@astrojs/starlight/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import CodeCard from '../components/CodeCard.astro';
import NudgeCard from '../components/NudgeCard.astro';

const twoLayerCore = `"""acme — client for the Acme directory."""

import os
import httpx

# --- core logic (portable — keeps on graduation) ---

async def lookup(company_id: str) -> dict:
    """Look up a company. -> {name, address, ...}"""
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const twoLayerWiring = `# --- repld wiring (shed on graduation) ---

__repld_tools__ = [
    {"name": "lookup", "description": "Look up a company",
     "inputSchema": {"type": "object",
                     "properties": {"company_id": {"type": "string"}},
                     "required": ["company_id"]}},
]

async def _tool_lookup(args: dict) -> str:
    import json
    result = await lookup(args["company_id"])
    return json.dumps(result)`;

const fetchPattern = `# Browser-auth variant — accept a fetch callable
# Works with browser session (no token) AND standalone (token from env)

async def lookup(company_id: str, *, fetch=None) -> dict:
    """Look up a company. -> {name, address, ...}"""
    if fetch is not None:
        return (await fetch(f"/api/company/{company_id}"))["body"]
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const envSnippet = `# .env at project root — loaded by repld at boot,
# by FastAPI/FastMCP in production. Same file, both contexts.

API_TOKEN=sk-live-abc123
ACME_API_KEY=xyz789
DATABASE_URL=postgresql://localhost/mydb`;

const fastmcpSnippet = `from fastmcp import FastMCP
from gists.acme import lookup

mcp = FastMCP("my-service")

# One line — schema generated from type hints + docstring
mcp.add_tool(lookup)`;

const fastmcpDecoratorSnippet = `# When you need a different name or adapted parameters:
@mcp.tool
async def company_lookup(company_id: str) -> dict:
    """Look up a company."""
    return await lookup(company_id)`;

const fastapiSnippet = `from fastapi import APIRouter
from gists.acme import lookup

router = APIRouter()

@router.get("/company/{company_id}")
async def company_lookup(company_id: str):
    return await lookup(company_id)`;

const scaffoldSnippet = `$ uv init my-service && cd my-service

# Add framework
$ uv add fastmcp                # or: uv add fastapi uvicorn

# Add gist deps (from __repld_deps__)
$ uv add httpx

# If browser-backed:
$ uv add repld-tool[browser]

# Copy gists (vendor them)
$ mkdir -p gists
$ cp ~/other-project/gists/acme.py gists/

# Run
$ uv run fastmcp run server.py  # FastMCP
$ uv run uvicorn main:app       # FastAPI`;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout
	title="Production — repld"
	description="Graduate gists from interactive prototyping to production services. FastMCP, FastAPI — same code, different harness."
	active="production"
>
	<!-- ==================== hero ==================== -->
	<section class="hero">
		<p class="tag">production</p>
		<h1 class="display">From gist<br />to service.</h1>
		<p class="hero-sub">
			A gist is a plain Python file. It runs in repld during prototyping and in FastMCP or FastAPI
			in production. Same code, different harness. This page shows how to wire it.
		</p>
	</section>

	<!-- ==================== two-layer pattern ==================== -->
	<Section label="the two-layer pattern">
		<h2 class="display sm">Core logic stays.<br />Wiring gets replaced.</h2>
		<p class="body-text">
			Write gists with two layers: core logic at the top (portable, moves to production unchanged)
			and repld wiring at the bottom (<code class="c">__repld_tools__</code> +
			<code class="c">_tool_*</code> — shed on graduation, replaced by <code class="c"
				>@mcp.tool</code
			> or <code class="c">@router.get</code>).
		</p>
		<div class="code-stack" data-reveal>
			<CodeCard code={twoLayerCore} label="keeps" labelTone="accent" class="keeps" />
			<div class="seam" aria-hidden="true">
				<span class="seam-dot"></span>
				<span class="seam-label">graduation seam</span>
			</div>
			<CodeCard code={twoLayerWiring} label="sheds" labelTone="dim" class="sheds" />
		</div>
	</Section>

	<!-- ==================== fetch callable ==================== -->
	<Section label="browser auth portability">
		<div class="split">
			<div>
				<h2 class="display sm">The browser is the credential.</h2>
				<p class="body-text">
					For APIs with session auth (no API key), accept a <code class="c">fetch=</code>
					callable. In repld, pass <code class="c">tab.fetch</code>. In production, pass an httpx
					client or switch to token auth. The core function doesn't care which path.
				</p>
			</div>
			<CodeCard code={fetchPattern} />
		</div>
	</Section>

	<!-- ==================== secrets / .env ==================== -->
	<Section label="secrets">
		<div class="split">
			<div>
				<h2 class="display sm">One <code class="c">.env</code>,<br />both contexts.</h2>
				<p class="body-text">
					Core logic reads <code class="c">os.environ</code> — never hardcode tokens. repld loads <code
						class="c">.env</code
					> from the project root at kernel boot. Production frameworks load the same file their own way.
					The gist code is identical.
				</p>
			</div>
			<CodeCard code={envSnippet} lang="bash" />
		</div>
	</Section>

	<!-- ==================== three tiers ==================== -->
	<Section label="graduation tiers">
		<h2 class="display sm">Pick the tier that fits.</h2>
		<p class="body-text">
			Not every gist needs the same production setup. Some use public APIs with tokens, some need
			the browser's authenticated session, some use both.
		</p>
		<div class="table-wrap" data-reveal>
			<table>
				<thead>
					<tr>
						<th>Tier</th>
						<th>Auth</th>
						<th>repld dep?</th>
						<th>When</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td class="lname">Standalone</td>
						<td><code class="c">.env</code> tokens</td>
						<td>No</td>
						<td>Stable API, you have keys</td>
					</tr>
					<tr>
						<td class="lname">Browser-backed</td>
						<td><code class="c">browser.fetch()</code></td>
						<td><code class="c">repld-tool[browser]</code></td>
						<td>Session-auth APIs, no proper keys</td>
					</tr>
					<tr>
						<td class="lname">Hybrid</td>
						<td>Token + browser fallback</td>
						<td>Optional</td>
						<td>Token when available, browser otherwise</td>
					</tr>
				</tbody>
			</table>
		</div>
	</Section>

	<!-- ==================== fastmcp ==================== -->
	<Section label="fastmcp">
		<div class="split">
			<div>
				<h2 class="display sm">One line to<br />an MCP tool.</h2>
				<p class="body-text">
					<code class="c">mcp.add_tool()</code> generates the input schema from type hints and the description
					from the docstring. If your core function's signature already matches, this is all you need.
				</p>
			</div>
			<div class="code-stack-sm" data-reveal>
				<CodeCard code={fastmcpSnippet} />
				<CodeCard code={fastmcpDecoratorSnippet} />
			</div>
		</div>
	</Section>

	<!-- ==================== fastapi ==================== -->
	<Section label="fastapi">
		<div class="split">
			<div>
				<h2 class="display sm">Same function,<br />HTTP endpoint.</h2>
				<p class="body-text">
					Wrap the core function with a route decorator. FastAPI handles validation, serialization,
					and OpenAPI docs. The gist doesn't change.
				</p>
			</div>
			<CodeCard code={fastapiSnippet} />
		</div>
	</Section>

	<!-- ==================== scaffolding ==================== -->
	<Section label="scaffolding">
		<h2 class="display sm">Seven commands to a running service.</h2>
		<p class="body-text">
			Create a project, add deps, copy gists, run. The <code class="c">__repld_tools__</code>
			layer stays behind — <code class="c">@mcp.tool</code> or <code class="c">@router.get</code>
			replaces it.
		</p>
		<CodeCard code={scaffoldSnippet} lang="bash" class="wide" />
	</Section>

	<!-- ==================== what stays / what goes ==================== -->
	<Section label="what stays, what goes">
		<h2 class="display sm">The seam is clean.</h2>
		<div class="compare" data-reveal>
			<div class="compare-col stays">
				<h3 class="compare-head accent">Stays <span class="dim">(portable)</span></h3>
				<ul>
					<li>Core async functions</li>
					<li>Type hints + docstrings</li>
					<li><code class="c">os.environ["TOKEN"]</code></li>
					<li>Data parsing helpers</li>
					<li><code class="c">__repld_deps__</code> <span class="dim">(as reference)</span></li>
				</ul>
			</div>
			<div class="compare-col goes">
				<h3 class="compare-head">Goes <span class="dim">(repld-specific)</span></h3>
				<ul>
					<li><code class="c">__repld_tools__</code> list</li>
					<li><code class="c">_tool_*</code> handler functions</li>
					<li><code class="c">import repld</code> <span class="dim">(in wiring)</span></li>
					<li><code class="c">tab.fetch</code> / <code class="c">browser.get</code></li>
					<li><code class="c">__repld_usage__</code></li>
				</ul>
			</div>
		</div>
	</Section>

	<!-- ==================== nudge claude ==================== -->
	<Section label="nudge claude">
		<h2 class="display sm">Say this when you're ready.</h2>
		<p class="body-text">
			Claude reads the production guide on demand. One line sets the context for the whole
			graduation conversation.
		</p>
		<div class="nudge-grid" data-reveal>
			<NudgeCard
				when="Starting the conversation"
				say="Read repld://docs/production — let's graduate this gist"
			/>
			<NudgeCard
				when="Standalone service"
				say="Set up a FastMCP server for this gist — no browser needed"
			/>
			<NudgeCard
				when="Browser-backed service"
				say="Graduate this to FastAPI with repld-tool[browser]"
			/>
		</div>
	</Section>

	<!-- ==================== outro ==================== -->
	<section class="outro" data-anim>
		<blockquote data-reveal>
			The gist is the seam between discovery and production. You prototype interactively — poking at
			APIs, reverse-engineering traffic, shaping the data. When it works, you copy the file, swap
			the wiring, and run it headless. Nothing is rewritten. The playbook's progression doesn't end
			at the REPL — it ends at a running service.
		</blockquote>
		<div class="back-links" data-reveal>
			<a href={`${base}playbook`}><Icon name="left-arrow" size="1em" /> the playbook</a>
			<a href={`${base}quickstart`}>quickstart <Icon name="right-arrow" size="1em" /></a>
		</div>
	</section>
</BaseLayout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);
	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!reduced) {
		// The graduation-seam dot travels left→right as the seam scrolls past —
		// the moment the wiring is shed and the core graduates.
		const seam = document.querySelector<HTMLElement>('.seam');
		const dot = document.querySelector<HTMLElement>('.seam-dot');
		if (seam && dot) {
			gsap.fromTo(
				dot,
				{ left: '0%', autoAlpha: 0 },
				{
					left: '100%',
					autoAlpha: 1,
					ease: 'none',
					scrollTrigger: {
						trigger: seam,
						start: 'top 88%',
						end: 'top 32%',
						scrub: 0.5,
					},
				},
			);
		}

		// Tier rows light up their left edge as they enter.
		gsap.utils.toArray<HTMLElement>('tbody tr').forEach((row) => {
			gsap.from(row, {
				autoAlpha: 0,
				x: -16,
				duration: 0.5,
				ease: 'power2.out',
				scrollTrigger: { trigger: row, start: 'top 90%' },
			});
		});
	}
</script>

<style>
	/* code stacks — page-specific composition of shared cards */
	.code-stack {
		display: flex;
		flex-direction: column;
	}
	.code-stack :global(.code-card.keeps) {
		border-bottom-left-radius: 0;
		border-bottom-right-radius: 0;
		border-bottom: none;
		border-color: var(--accent-line);
	}
	.code-stack :global(.code-card.sheds) {
		border-top-left-radius: 0;
		border-top-right-radius: 0;
		opacity: 0.45;
		filter: saturate(0.4);
		transition:
			opacity 0.5s ease,
			filter 0.5s ease;
	}
	/* sheds "re-attaches" on hover — the wiring is still there, just dormant */
	.code-stack:hover :global(.code-card.sheds) {
		opacity: 0.8;
		filter: saturate(0.8);
	}

	/* the graduation seam — where wiring is shed */
	.seam {
		position: relative;
		height: 0;
		border-top: 1px dashed var(--accent-glow);
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			linear-gradient(var(--color-panel-2), var(--color-panel-2)) padding-box,
			repeating-linear-gradient(90deg, var(--accent-glow) 0 6px, transparent 6px 12px);
	}
	.seam-label {
		position: absolute;
		transform: translateY(-50%);
		top: 0;
		background: var(--color-ink);
		color: var(--color-accent);
		font-size: 10px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		padding: 3px 12px;
		border: 1px solid var(--accent-line);
		border-radius: 999px;
	}
	.seam-dot {
		position: absolute;
		left: 0;
		top: 0;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--color-accent);
		box-shadow: 0 0 12px 2px var(--color-accent);
		transform: translate(-50%, -50%);
		opacity: 0;
	}
	.code-stack-sm {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	:global(.code-card.wide) {
		max-width: 680px;
	}

	/* tier table */
	.table-wrap {
		overflow-x: auto;
	}
	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 13.5px;
	}
	th {
		text-align: left;
		color: var(--color-muted);
		font-weight: 500;
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 12px 14px;
		border-bottom: 1px solid var(--color-line);
	}
	tbody tr {
		transition: background 0.2s;
	}
	tbody tr:hover {
		background: rgb(60 232 130 / 0.03);
	}
	td {
		padding: 14px;
		color: var(--color-fg);
		border-bottom: 1px solid rgb(28 36 47 / 0.3);
		vertical-align: top;
	}
	.lname {
		color: var(--color-bright);
		font-weight: 500;
		white-space: nowrap;
		border-left: 2px solid transparent;
		padding-left: 12px;
		margin-left: -14px;
		transition: border-color 0.2s;
	}
	tbody tr:hover .lname {
		border-color: var(--color-accent);
	}

	/* comparison */
	.compare {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 16px;
		max-width: 720px;
	}
	.compare-col {
		border: 1px solid var(--color-line);
		border-radius: 10px;
		padding: 24px 22px;
		background: var(--color-panel);
	}
	.compare-col.stays {
		border-color: rgb(60 232 130 / 0.25);
	}
	.compare-head {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 14px;
		margin-bottom: 16px;
		color: var(--color-bright);
	}
	.compare-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.compare-col li {
		color: var(--color-fg);
		font-size: 13.5px;
		padding-left: 16px;
		position: relative;
	}
	.compare-col li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 8px;
		width: 6px;
		height: 6px;
		border-radius: 50%;
	}
	.stays li::before {
		background: var(--color-accent);
	}
	.goes li::before {
		background: var(--color-muted);
		opacity: 0.5;
	}

	/* nudge grid */
	.nudge-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
		margin-top: 8px;
	}

	/* outro back-links */
	.back-links {
		margin-top: 32px;
		display: flex;
		gap: 32px;
	}
	.back-links a {
		font-size: 15px;
		color: var(--color-accent);
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.back-links a :global(svg) {
		width: 1em;
		height: 1em;
	}

	@media (max-width: 900px) {
		.compare,
		.nudge-grid {
			grid-template-columns: minmax(0, 1fr);
		}
	}
</style>
