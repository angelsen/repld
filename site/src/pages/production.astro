---
import { Font } from 'astro:assets';
import { Code } from 'astro:components';
import { Icon } from '@astrojs/starlight/components';
import vesper from '@shikijs/themes/vesper';
import '../styles/global.css';

const twoLayerCore = `"""acme — client for the Acme directory."""

import os
import httpx

# --- core logic (portable — keeps on graduation) ---

async def lookup(company_id: str) -> dict:
    """Look up a company. -> {name, address, ...}"""
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const twoLayerWiring = `# --- repld wiring (shed on graduation) ---

__repld_tools__ = [
    {"name": "lookup", "description": "Look up a company",
     "inputSchema": {"type": "object",
                     "properties": {"company_id": {"type": "string"}},
                     "required": ["company_id"]}},
]

async def _tool_lookup(args: dict) -> str:
    import json
    result = await lookup(args["company_id"])
    return json.dumps(result)`;

const fetchPattern = `# Browser-auth variant — accept a fetch callable
# Works with browser session (no token) AND standalone (token from env)

async def lookup(company_id: str, *, fetch=None) -> dict:
    """Look up a company. -> {name, address, ...}"""
    if fetch is not None:
        return (await fetch(f"/api/company/{company_id}"))["body"]
    async with httpx.AsyncClient() as c:
        resp = await c.get(
            f"https://api.example.com/company/{company_id}",
            headers={"Authorization": f"Bearer {os.environ['API_TOKEN']}"},
        )
        return resp.json()`;

const envSnippet = `# .env at project root — loaded by repld at boot,
# by FastAPI/FastMCP in production. Same file, both contexts.

API_TOKEN=sk-live-abc123
ACME_API_KEY=xyz789
DATABASE_URL=postgresql://localhost/mydb`;

const fastmcpSnippet = `from fastmcp import FastMCP
from gists.acme import lookup

mcp = FastMCP("my-service")

# One line — schema generated from type hints + docstring
mcp.add_tool(lookup)`;

const fastmcpDecoratorSnippet = `# When you need a different name or adapted parameters:
@mcp.tool
async def company_lookup(company_id: str) -> dict:
    """Look up a company."""
    return await lookup(company_id)`;

const fastapiSnippet = `from fastapi import APIRouter
from gists.acme import lookup

router = APIRouter()

@router.get("/company/{company_id}")
async def company_lookup(company_id: str):
    return await lookup(company_id)`;

const scaffoldSnippet = `$ uv init my-service && cd my-service

# Add framework
$ uv add fastmcp                # or: uv add fastapi uvicorn

# Add gist deps (from __repld_deps__)
$ uv add httpx

# If browser-backed:
$ uv add repld-tool[browser]

# Copy gists (vendor them)
$ mkdir -p gists
$ cp ~/other-project/gists/acme.py gists/

# Run
$ uv run fastmcp run server.py  # FastMCP
$ uv run uvicorn main:app       # FastAPI`;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Production — repld</title>
		<meta
			name="description"
			content="Graduate gists from interactive prototyping to production services. FastMCP, FastAPI — same code, different harness."
		/>
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<Font cssVariable="--font-geist-mono" preload />
		<Font cssVariable="--font-bricolage" preload />
	</head>
	<body>
		<header class="nav">
			<a class="wordmark" href={base}>repld<span class="blink"></span></a>
			<nav class="links">
				<a href={base}>home</a>
				<a href={`${base}playbook`}>playbook</a>
				<a href={`${base}docs/`}>docs</a>
				<a href="https://github.com/angelsen/repld">github</a>
			</nav>
		</header>

		<main>
			<!-- ==================== hero ==================== -->
			<section class="hero">
				<p class="tag">production</p>
				<h1 class="display">From gist<br />to service.</h1>
				<p class="hero-sub">
					A gist is a plain Python file. It runs in repld during prototyping and in
					FastMCP or FastAPI in production. Same code, different harness. This page
					shows how to wire it.
				</p>
			</section>

			<!-- ==================== two-layer pattern ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>the two-layer pattern</div>
				<h2 class="display sm">Core logic stays.<br />Wiring gets replaced.</h2>
				<p class="body-text">
					Write gists with two layers: core logic at the top (portable, moves to production
					unchanged) and repld wiring at the bottom (<code class="c">__repld_tools__</code> +
					<code class="c">_tool_*</code> — shed on graduation, replaced by <code class="c"
						>@mcp.tool</code
					> or <code class="c">@router.get</code>).
				</p>
				<div class="code-stack" data-reveal>
					<div class="code-card keeps">
						<div class="code-label accent">keeps</div>
						<Code code={twoLayerCore} lang="python" theme={vesper} />
					</div>
					<div class="code-card sheds">
						<div class="code-label dim">sheds</div>
						<Code code={twoLayerWiring} lang="python" theme={vesper} />
					</div>
				</div>
			</section>

			<!-- ==================== fetch callable ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>browser auth portability</div>
				<div class="split">
					<div>
						<h2 class="display sm">The browser is the credential.</h2>
						<p class="body-text">
							For APIs with session auth (no API key), accept a <code class="c">fetch=</code>
							 callable. In repld, pass <code class="c">tab.fetch</code>. In production, pass
							an httpx client or switch to token auth. The core function doesn't care which path.
						</p>
					</div>
					<div class="code-card" data-reveal>
						<Code code={fetchPattern} lang="python" theme={vesper} />
					</div>
				</div>
			</section>

			<!-- ==================== secrets / .env ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>secrets</div>
				<div class="split">
					<div>
						<h2 class="display sm">One <code class="c">.env</code>,<br />both contexts.</h2>
						<p class="body-text">
							Core logic reads <code class="c">os.environ</code> — never hardcode tokens. repld
							loads <code class="c">.env</code> from the project root at kernel boot. Production
							frameworks load the same file their own way. The gist code is identical.
						</p>
					</div>
					<div class="code-card" data-reveal>
						<Code code={envSnippet} lang="bash" theme={vesper} />
					</div>
				</div>
			</section>

			<!-- ==================== three tiers ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>graduation tiers</div>
				<h2 class="display sm">Pick the tier that fits.</h2>
				<p class="body-text">
					Not every gist needs the same production setup. Some use public APIs with tokens,
					some need the browser's authenticated session, some use both.
				</p>
				<div class="table-wrap" data-reveal>
					<table>
						<thead>
							<tr>
								<th>Tier</th>
								<th>Auth</th>
								<th>repld dep?</th>
								<th>When</th>
							</tr>
						</thead>
						<tbody>
							<tr>
								<td class="lname">Standalone</td>
								<td><code class="c">.env</code> tokens</td>
								<td>No</td>
								<td>Stable API, you have keys</td>
							</tr>
							<tr>
								<td class="lname">Browser-backed</td>
								<td><code class="c">browser.fetch()</code></td>
								<td><code class="c">repld-tool[browser]</code></td>
								<td>Session-auth APIs, no proper keys</td>
							</tr>
							<tr>
								<td class="lname">Hybrid</td>
								<td>Token + browser fallback</td>
								<td>Optional</td>
								<td>Token when available, browser otherwise</td>
							</tr>
						</tbody>
					</table>
				</div>
			</section>

			<!-- ==================== fastmcp ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>fastmcp</div>
				<div class="split">
					<div>
						<h2 class="display sm">One line to<br />an MCP tool.</h2>
						<p class="body-text">
							<code class="c">mcp.add_tool()</code> generates the input schema from type hints
							and the description from the docstring. If your core function's signature already
							matches, this is all you need.
						</p>
					</div>
					<div class="code-stack-sm" data-reveal>
						<div class="code-card">
							<Code code={fastmcpSnippet} lang="python" theme={vesper} />
						</div>
						<div class="code-card">
							<Code code={fastmcpDecoratorSnippet} lang="python" theme={vesper} />
						</div>
					</div>
				</div>
			</section>

			<!-- ==================== fastapi ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>fastapi</div>
				<div class="split">
					<div>
						<h2 class="display sm">Same function,<br />HTTP endpoint.</h2>
						<p class="body-text">
							Wrap the core function with a route decorator. FastAPI handles validation,
							serialization, and OpenAPI docs. The gist doesn't change.
						</p>
					</div>
					<div class="code-card" data-reveal>
						<Code code={fastapiSnippet} lang="python" theme={vesper} />
					</div>
				</div>
			</section>

			<!-- ==================== scaffolding ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>scaffolding</div>
				<h2 class="display sm">Seven commands to a running service.</h2>
				<p class="body-text">
					Create a project, add deps, copy gists, run. The <code class="c">__repld_tools__</code>
					 layer stays behind — <code class="c">@mcp.tool</code> or <code class="c">@router.get</code>
					 replaces it.
				</p>
				<div class="code-card wide" data-reveal>
					<Code code={scaffoldSnippet} lang="bash" theme={vesper} />
				</div>
			</section>

			<!-- ==================== what stays / what goes ==================== -->
			<section class="section" data-anim>
				<div class="section-label"><span class="dot"></span>what stays, what goes</div>
				<h2 class="display sm">The seam is clean.</h2>
				<div class="compare" data-reveal>
					<div class="compare-col stays">
						<h3 class="compare-head accent">Stays <span class="dim">(portable)</span></h3>
						<ul>
							<li>Core async functions</li>
							<li>Type hints + docstrings</li>
							<li><code class="c">os.environ["TOKEN"]</code></li>
							<li>Data parsing helpers</li>
							<li><code class="c">__repld_deps__</code> <span class="dim">(as reference)</span></li>
						</ul>
					</div>
					<div class="compare-col goes">
						<h3 class="compare-head">Goes <span class="dim">(repld-specific)</span></h3>
						<ul>
							<li><code class="c">__repld_tools__</code> list</li>
							<li><code class="c">_tool_*</code> handler functions</li>
							<li><code class="c">import repld</code> <span class="dim">(in wiring)</span></li>
							<li><code class="c">tab.fetch</code> / <code class="c">browser.get</code></li>
							<li><code class="c">__repld_usage__</code></li>
						</ul>
					</div>
				</div>
			</section>

			<!-- ==================== outro ==================== -->
			<section class="outro" data-anim>
				<blockquote data-reveal>
					The gist is the seam between discovery and production. You prototype
					interactively — poking at APIs, reverse-engineering traffic, shaping the
					data. When it works, you copy the file, swap the wiring, and run it
					headless. Nothing is rewritten. The playbook's progression doesn't end at
					the REPL — it ends at a running service.
				</blockquote>
				<div class="back-links" data-reveal>
					<a href={`${base}playbook`}><Icon name="left-arrow" size="1em" /> the playbook</a>
					<a href={`${base}quickstart`}>quickstart <Icon name="right-arrow" size="1em" /></a>
				</div>
			</section>
		</main>

		<footer class="ft">
			<span class="wordmark sm-wm">repld<span class="blink"></span></span>
			<nav class="links">
				<a href={`${base}docs/`}>docs</a>
				<a href="https://pypi.org/project/repld-tool/">pypi</a>
				<a href="https://github.com/angelsen/repld">github</a>
			</nav>
		</footer>

		<script>
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			import { SplitText } from 'gsap/SplitText';
			import Lenis from 'lenis';

			gsap.registerPlugin(ScrollTrigger, SplitText);
			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (!reduced) {
				const lenis = new Lenis({ autoRaf: false, lerp: 0.12 });
				lenis.on('scroll', ScrollTrigger.update);
				gsap.ticker.add((t) => lenis.raf(t * 1000));
				gsap.ticker.lagSmoothing(0);

				document.fonts.ready.then(() => {
					const heroSplit = SplitText.create('.hero h1', { type: 'lines', mask: 'lines' });
					gsap.from(heroSplit.lines, {
						yPercent: 115,
						duration: 0.9,
						stagger: 0.09,
						ease: 'power4.out',
						onComplete: () => heroSplit.revert(),
					});
					gsap.from('.tag', { y: 16, autoAlpha: 0, duration: 0.5, ease: 'power3.out' });
					gsap.from('.hero-sub', {
						y: 22,
						autoAlpha: 0,
						duration: 0.7,
						ease: 'power3.out',
						delay: 0.3,
					});

					document.querySelectorAll<HTMLElement>('[data-anim] h2').forEach((el) => {
						const s = SplitText.create(el, { type: 'lines', mask: 'lines' });
						gsap.from(s.lines, {
							yPercent: 115,
							duration: 0.85,
							stagger: 0.09,
							ease: 'power4.out',
							scrollTrigger: { trigger: el, start: 'top 82%' },
							onComplete: () => s.revert(),
						});
					});
				});

				document.querySelectorAll<HTMLElement>('[data-anim]').forEach((sect) => {
					const els = sect.querySelectorAll('[data-reveal], .body-text, .section-label');
					if (!els.length) return;
					gsap.from(els, {
						y: 26,
						autoAlpha: 0,
						duration: 0.7,
						stagger: 0.1,
						ease: 'power3.out',
						scrollTrigger: { trigger: sect, start: 'top 72%' },
					});
				});
			}
		</script>

		<style>
			/* ========== tokens (page-scoped) ========== */
			main {
				max-width: 1080px;
				margin: 0 auto;
				padding: 0 24px;
			}

			.display {
				font-family: var(--font-display);
				font-weight: 800;
				color: var(--color-bright);
				letter-spacing: -0.02em;
				line-height: 1.05;
			}
			.display.sm {
				font-size: clamp(1.9rem, 3.6vw, 2.9rem);
				margin-bottom: 18px;
			}
			.dim {
				color: var(--color-muted);
			}
			.accent {
				color: var(--color-accent);
			}
			code.c {
				color: var(--color-accent);
				background: rgb(60 232 130 / 0.07);
				border: 1px solid rgb(60 232 130 / 0.18);
				border-radius: 4px;
				padding: 0 5px;
				font-size: 0.92em;
			}
			.body-text {
				color: var(--color-muted);
				max-width: 52ch;
				margin-bottom: 32px;
				line-height: 1.75;
			}

			/* ========== nav ========== */
			.nav {
				max-width: 1080px;
				margin: 0 auto;
				padding: 22px 24px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.wordmark {
				font-weight: 700;
				font-size: 19px;
				color: var(--color-bright);
				text-decoration: none;
			}
			.sm-wm {
				font-size: 15px;
			}
			.blink {
				display: inline-block;
				width: 9px;
				height: 1em;
				margin-left: 2px;
				vertical-align: text-bottom;
				background: var(--color-accent);
				animation: blink 1.06s steps(1) infinite;
			}
			@keyframes blink {
				50% {
					opacity: 0;
				}
			}
			.links {
				display: flex;
				gap: 24px;
			}
			.links a,
			.back-links a {
				color: var(--color-muted);
				text-decoration: none;
				font-size: 13.5px;
				letter-spacing: 0.04em;
				background: linear-gradient(var(--color-accent), var(--color-accent)) no-repeat left
					bottom / 0% 1px;
				transition:
					color 0.18s,
					background-size 0.25s;
				padding-bottom: 2px;
			}
			.links a:hover,
			.back-links a:hover {
				color: var(--color-accent);
				background-size: 100% 1px;
			}

			/* ========== hero ========== */
			.hero {
				padding: 72px 0 76px;
				max-width: 680px;
				position: relative;
			}
			.hero::before {
				content: '';
				position: absolute;
				top: -20%;
				right: -50%;
				width: 80%;
				height: 100%;
				background: radial-gradient(
					ellipse at center,
					rgb(60 232 130 / 0.05),
					transparent 65%
				);
				pointer-events: none;
			}
			.tag {
				color: var(--color-accent);
				font-size: 12px;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				margin-bottom: 22px;
			}
			.hero h1 {
				font-size: clamp(3rem, 6vw, 5rem);
				margin-bottom: 28px;
			}
			.hero-sub {
				color: var(--color-muted);
				font-size: 16px;
				line-height: 1.8;
				max-width: 56ch;
			}

			/* ========== sections ========== */
			.section {
				padding: 84px 0;
				border-top: 1px solid rgb(28 36 47 / 0.55);
			}
			.section-label {
				display: flex;
				align-items: center;
				gap: 10px;
				color: var(--color-muted);
				font-size: 12px;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				margin-bottom: 38px;
			}
			.dot {
				width: 9px;
				height: 9px;
				border-radius: 50%;
				border: 1px solid var(--color-muted);
			}

			/* ========== split layout ========== */
			.split {
				display: grid;
				grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
				gap: 48px;
				align-items: start;
			}

			/* ========== code cards ========== */
			.code-card {
				border: 1px solid var(--color-line);
				border-radius: 10px;
				overflow: hidden;
				background: var(--color-panel-2);
				position: relative;
			}
			.code-card :global(pre) {
				padding: 20px 22px;
				font-size: 13.5px;
				line-height: 1.8;
				background: transparent !important;
				overflow-x: auto;
			}
			.code-card.wide {
				max-width: 680px;
			}
			.code-label {
				position: absolute;
				top: 12px;
				right: 16px;
				font-size: 10px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				z-index: 1;
			}

			/* stacked code cards */
			.code-stack {
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.code-stack .code-card.keeps {
				border-bottom-left-radius: 0;
				border-bottom-right-radius: 0;
				border-bottom: none;
				border-color: rgb(60 232 130 / 0.2);
			}
			.code-stack .code-card.sheds {
				border-top-left-radius: 0;
				border-top-right-radius: 0;
				border-color: var(--color-line);
				opacity: 0.6;
			}
			.code-stack-sm {
				display: flex;
				flex-direction: column;
				gap: 12px;
			}

			/* ========== table ========== */
			.table-wrap {
				overflow-x: auto;
			}
			table {
				width: 100%;
				border-collapse: collapse;
				font-size: 13.5px;
			}
			th {
				text-align: left;
				color: var(--color-muted);
				font-weight: 500;
				font-size: 11px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 12px 14px;
				border-bottom: 1px solid var(--color-line);
			}
			td {
				padding: 14px;
				color: var(--color-fg);
				border-bottom: 1px solid rgb(28 36 47 / 0.3);
				vertical-align: top;
			}
			.lname {
				color: var(--color-bright);
				font-weight: 500;
				white-space: nowrap;
			}

			/* ========== comparison ========== */
			.compare {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
				gap: 16px;
				max-width: 720px;
			}
			.compare-col {
				border: 1px solid var(--color-line);
				border-radius: 10px;
				padding: 24px 22px;
				background: var(--color-panel);
			}
			.compare-col.stays {
				border-color: rgb(60 232 130 / 0.25);
			}
			.compare-head {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 14px;
				margin-bottom: 16px;
				color: var(--color-bright);
			}
			.compare-col ul {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 10px;
			}
			.compare-col li {
				color: var(--color-fg);
				font-size: 13.5px;
				padding-left: 16px;
				position: relative;
			}
			.compare-col li::before {
				content: '';
				position: absolute;
				left: 0;
				top: 8px;
				width: 6px;
				height: 6px;
				border-radius: 50%;
			}
			.stays li::before {
