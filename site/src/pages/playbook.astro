---
import { Icon } from '@astrojs/starlight/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import CodeCard from '../components/CodeCard.astro';

const gistSnippet = `gists/                  # pure Python, no framework dependency
  inventory.py         # ERP lookup, sheet write
  notify.py            # Slack / email dispatch

repld                   # imports gists for interactive prototyping
fastapi                 # imports gists for production endpoints
inngest                 # calls gists as durable step functions`;

const gateSnippet = `# auto stages fill themselves; human stages wait
[Auto]   Finding      → system analyzes, writes result
[Human]  Decision     → human reviews, writes action        # ← gate
[Auto]   Execution    → system executes the action
[Auto]   Status       → Pending → Done`;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const principles = [
	{
		t: 'One service, one job',
		d: 'Each function takes input, returns output. They compose through data, not shared frameworks.',
	},
	{
		t: 'UI is a view, not the system',
		d: 'Pipeline state lives in plain data. Any UI can read or write it. Swap the view without touching the pipeline.',
	},
	{
		t: 'Prototype interactive, harden headless',
		d: 'Start by doing it manually. Each ad-hoc action becomes a gist. Each gist becomes a callable stage.',
	},
	{
		t: 'Human gates are just empty fields',
		d: 'A column waiting for input, a DB field set to null, a waitForEvent — same concept. The pipeline pauses until a human fills it.',
	},
	{
		t: 'State is plain data',
		d: 'JSON in, JSON out. Spreadsheet columns, DB columns, and pipeline inputs are the same thing.',
	},
	{
		t: "Discover, don't design",
		d: "Do the work manually first. Extract stages only when you've done the same thing three times.",
	},
];

const layers = [
	['Capture', 'Web app, phone camera, manual entry', 'Same, or webhook / API trigger'],
	['AI reasoning', 'Claude Code (human steers)', 'Claude API (prompt hardened)'],
	['Glue', 'repld gist (ad-hoc, stateful)', 'FastAPI / Inngest (durable)'],
	['State / UI', 'Spreadsheet, DB, file dump', 'Same — UI is just a view'],
	['Integration', 'MCP tools (browser, APIs)', 'Same MCP tools, called from code'],
];

const steps = [
	{
		t: 'Interactive',
		d: 'You and Claude work a task in repld. Poke at the browser, hit an API, inspect the result. No plan — just doing.',
	},
	{
		t: 'Scripted',
		d: 'You repeated it three times. Extract a gist — a plain Python file the kernel hot-reloads. Same code, now importable.',
	},
	{
		t: 'Semi-auto',
		d: 'Wire a trigger: @every, a webhook, a queue. Human gates where ambiguity requires judgment.',
	},
	{
		t: 'Production',
		d: 'Event-driven, durable, monitored. Gists from phase 2 are now production steps. Nothing was thrown away.',
	},
];
---

<BaseLayout
	title="The Playbook — repld"
	description="How automation actually gets built: do it by hand, extract a gist, wire a trigger, ship it headless. The method is the same regardless of the tools."
	active="playbook"
>
	<!-- ==================== hero ==================== -->
	<section class="hero">
		<p class="tag">how we build</p>
		<h1 class="display">The Playbook</h1>
		<p class="hero-sub">
			Discovered through practice, not designed upfront. Works for any automation — fully automatic
			pipelines, human-in-the-loop processes, AI-augmented flows, or plain data transforms.
		</p>
	</section>

	<!-- ==================== principles ==================== -->
	<Section label="principles">
		<div class="cards-grid">
			{
				principles.map((p) => (
					<div class="card">
						<h3>{p.t}</h3>
						<p>{p.d}</p>
					</div>
				))
			}
		</div>
	</Section>

	<!-- ==================== layers ==================== -->
	<Section label="layers">
		<h2 class="display sm">Same code, different context.</h2>
		<p class="body-text">
			The interactive prototype and the production system share layers. What changes is the glue —
			not the logic.
		</p>
		<div class="table-wrap" data-reveal>
			<table>
				<thead>
					<tr><th>Layer</th><th>Interactive</th><th>Production</th></tr>
				</thead>
				<tbody>
					{
						layers.map(([l, i, p]) => (
							<tr>
								<td class="lname">{l}</td>
								<td>{i}</td>
								<td>{p}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>
	</Section>

	<!-- ==================== the gist ==================== -->
	<Section label="portable unit">
		<div class="split">
			<div>
				<h2 class="display sm">The gist is the seam.</h2>
				<p class="body-text">
					A plain Python file. Data in, data out. repld for prototyping, FastAPI for production,
					Inngest for durable workflows. Same file, different harness.
				</p>
			</div>
			<CodeCard code={gistSnippet} lang="bash" />
		</div>
	</Section>

	<!-- ==================== human gates ==================== -->
	<Section label="human gates">
		<div class="split">
			<div>
				<h2 class="display sm">The pipeline pauses for you.</h2>
				<p class="body-text">
					A human gate is just an empty field. Auto stages fill themselves; human stages wait. The
					UI can be anything — a spreadsheet, a dashboard, a Slack message, or nothing at all.
				</p>
			</div>
			<CodeCard code={gateSnippet} lang="python" />
		</div>
	</Section>

	<!-- ==================== the progression ==================== -->
	<Section label="the progression">
		<h2 class="display sm">Every tool starts as a conversation.</h2>
		<p class="body-text">
			Not every workflow needs every phase. Some jump to production, some stay semi-auto forever.
			Each phase reuses the previous one's artifacts.
		</p>
		<ol class="steps" data-reveal>
			{
				steps.map((s, i) => (
					<li class="step">
						<span class="step-n">{i + 1}</span>
						<div>
							<strong>{s.t}</strong>
							<p>{s.d}</p>
						</div>
					</li>
				))
			}
		</ol>
	</Section>

	<!-- ==================== outro ==================== -->
	<section class="outro" data-anim>
		<blockquote data-reveal>
			This playbook emerged from doing the work, not from planning it. Started as manual data entry
			and ad-hoc Claude sessions. By end of each project: multi-stage pipelines with OCR, AI
			enrichment, system sync, and human-in-the-loop gates — all built from gists that started as
			throwaway REPL code.
		</blockquote>
		<div class="back-links" data-reveal>
			<a href={base}><Icon name="left-arrow" size="1em" /> back to repld</a>
			<a href={`${base}production`}
				>graduating to production <Icon name="right-arrow" size="1em" /></a
			>
		</div>
	</section>
</BaseLayout>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);
	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (!reduced) {
		document.querySelectorAll<HTMLElement>('.step').forEach((step) => {
			ScrollTrigger.create({
				trigger: step,
				start: 'top 68%',
				onEnter: () => step.classList.add('lit'),
				onLeaveBack: () => step.classList.remove('lit'),
			});
		});
	}
</script>

<style>
	/* principle cards */
	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 14px;
	}
	.card {
		border: 1px solid var(--color-line);
		background: var(--color-panel);
		border-radius: 10px;
		padding: 24px 22px;
		display: flex;
		flex-direction: column;
		transition:
			border-color 0.2s,
			transform 0.2s;
	}
	.card:hover {
		border-color: var(--accent-glow);
		transform: translateY(-2px);
	}
	.card h3 {
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--color-bright);
		font-size: 15.5px;
		margin-bottom: 10px;
		line-height: 1.4;
	}
	.card p {
		color: var(--color-muted);
		font-size: 13px;
		line-height: 1.7;
		flex: 1;
	}

	/* layers table */
	.table-wrap {
		overflow-x: auto;
	}
	table {
		width: 100%;
		border-collapse: collapse;
		font-size: 13.5px;
	}
	th {
		text-align: left;
		color: var(--color-muted);
		font-weight: 500;
		font-size: 11px;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 12px 14px;
		border-bottom: 1px solid var(--color-line);
	}
	td {
		padding: 14px;
		color: var(--color-fg);
		border-bottom: 1px solid rgb(28 36 47 / 0.3);
		vertical-align: top;
	}
	.lname {
		color: var(--color-bright);
		font-weight: 500;
		white-space: nowrap;
	}

	/* progression steps */
	.steps {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		border-left: 1px solid var(--color-line);
		margin-left: 18px;
	}
	.step {
		display: flex;
		gap: 20px;
		align-items: flex-start;
		padding: 20px 0 20px 28px;
		position: relative;
		transition: background 0.3s;
	}
	.step-n {
		flex-shrink: 0;
		width: 36px;
		height: 36px;
		border-radius: 50%;
		border: 1px solid var(--color-line);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 14px;
		font-weight: 700;
		color: var(--color-muted);
		position: relative;
		transition: all 0.4s;
	}
	.step::before {
		content: '';
		position: absolute;
		left: -5px;
		top: 32px;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		border: 1px solid var(--color-line);
		background: var(--color-ink);
		transition: all 0.4s;
	}
	.step.lit::before {
		background: var(--color-accent);
		border-color: var(--color-accent);
		box-shadow: 0 0 10px rgb(60 232 130 / 0.6);
	}
	.step.lit .step-n {
		background: var(--color-accent);
		border-color: var(--color-accent);
		color: var(--color-ink);
		box-shadow: 0 0 16px rgb(60 232 130 / 0.5);
	}
	.step strong {
		font-family: var(--font-display);
		font-weight: 700;
		color: var(--color-bright);
		font-size: 16px;
		display: block;
		margin-bottom: 4px;
	}
	.step p {
		color: var(--color-muted);
		font-size: 13.5px;
		line-height: 1.7;
		max-width: 48ch;
		margin: 0;
	}

	/* outro back-links */
	.back-links {
		margin-top: 32px;
		display: flex;
		gap: 32px;
	}
	.back-links a {
		font-size: 15px;
		color: var(--color-accent);
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}
	.back-links a :global(svg) {
		width: 1em;
		height: 1em;
	}

	@media (max-width: 900px) {
		.cards-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 560px) {
		.cards-grid {
			grid-template-columns: minmax(0, 1fr);
		}
		.steps {
			margin-left: 10px;
		}
		.step {
			padding-left: 20px;
		}
	}
</style>
