---
import { Icon } from '@astrojs/starlight/components';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TerminalHero from '../components/TerminalHero.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const title = 'repld — AI that uses the apps you log into, and turns them into automations';
const description =
	'repld lets Claude use the web apps you already log into, reverse-engineer how they work, and turn them into automations you keep. It works even on apps with no public API.';

const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'repld',
	applicationCategory: 'DeveloperApplication',
	operatingSystem: 'Linux, macOS, Windows',
	description,
	url: new URL(base, Astro.site).toString(),
	downloadUrl: 'https://pypi.org/project/repld-tool/',
	softwareRequirements: 'Python 3.12+',
	author: { '@type': 'Person', name: 'Fredrik Angelsen', url: 'https://github.com/angelsen' },
	sameAs: ['https://github.com/angelsen/repld', 'https://pypi.org/project/repld-tool/'],
	offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body>
		<!-- kernel boot preloader (only rendered when JS is on; removed after play) -->
		<div id="boot" aria-hidden="true">
			<div class="boot-inner">
				<p class="boot-line">repld ▸ starting up</p>
				<p class="boot-line">▸ .pyrepl.lock written · socket ready</p>
				<p class="boot-line"><span class="boot-ok">▸ channel open</span></p>
			</div>
		</div>

		<!-- the wire: channel line running down the page -->
		<div class="wire" aria-hidden="true"><div class="wire-fill" id="wire-fill"></div></div>

		<Nav />

		<main>
			<!-- ============================ hero ============================ -->
			<section class="hero">
				<div class="hero-copy">
					<p class="kicker" data-hero>research preview · mcp</p>
					<h1 class="display" data-hero>
						AI that actually<br />
						<em>uses</em> your apps.
					</h1>
					<p class="sub" data-hero>
						Most AI is stuck in a chat box. repld is a live workspace you and Claude share. Point it
						at the apps you already log into, and Claude turns repetitive app-work into automations
						you keep — then watches them run, pushes results back in the background, and graduates
						them to production when you're ready.
					</p>
					<div class="install" data-hero>
						<code id="install-cmd"><span class="dim">$</span> uv tool install repld-tool</code>
						<button id="copy-btn" aria-label="Copy install command">copy</button>
					</div>
				</div>
				<div class="hero-term" data-hero>
					<TerminalHero />
				</div>
			</section>

			<!-- ============================ 01 one live workspace ============================ -->
			<section class="sect" data-sect>
				<p class="sect-label"><span class="node"></span>01 · one live workspace</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">You drive.<br />Claude codes.</h2>
						<p>
							You don't write Python. You use your apps and say what you want; Claude works in the
							same live session and turns it into code that runs. It all shares one state, so you
							can open anything it built.
						</p>
					</div>
					<div class="session-card" data-reveal>
						<div class="sc-bar"><span class="sc-dot"></span>live session</div>
						<div class="sc-body">
							<div class="sc-line sc-you">
								<span class="pr">you ❯</span><span class="sc-say"
									>"pull the open orders from the admin"</span
								>
							</div>
							<div class="sc-line sc-claude">
								<span class="pr">claude ❯</span><span class="sc-act"
									>orders = await sd.orders(status="open")</span
								>
							</div>
							<div class="sc-line sc-out">⤷ <span class="hl">317</span> open orders</div>
							<div class="sc-gap"></div>
							<div class="sc-line sc-you">
								<span class="pr">you ❯</span><span class="sc-say">"who's the biggest?"</span>
							</div>
							<div class="sc-line sc-claude">
								<span class="pr">claude ❯</span><span class="sc-act"
									>max(orders, key=lambda o: o.total)</span
								>
							</div>
							<div class="sc-line sc-out">
								⤷ <span class="hl">Nordlys Kafé AS</span> · 2 480,00 kr
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ============================ 02 operate your apps ============================ -->
			<section class="sect" data-sect>
				<p class="sect-label"><span class="node"></span>02 · operate your apps</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">In your real,<br />logged-in browser.</h2>
						<p>
							repld attaches to the Chrome you already use, logged into everything. Use the app
							yourself or let Claude click. Either way it sees every request and response, and turns
							what just happened into code.
						</p>
					</div>
					<div class="code-stack" data-reveal>
						<div class="session-card">
							<div class="sc-bar"><span class="sc-dot"></span>live session</div>
							<div class="sc-body">
								<div class="sc-line sc-you">
									<span class="pr">you ❯</span><span class="sc-say"
										>"export the products from the Shopify admin"</span
									>
								</div>
								<div class="sc-gap"></div>
								<div class="sc-line sc-claude">
									<span class="pr">claude ❯</span><span class="sc-act">clicked Export</span>
								</div>
								<div class="sc-line sc-out">
									⤷ POST /admin/exports <span class="hl">→ 201</span>
								</div>
								<div class="sc-line sc-out">⤷ 1,204 products · 2.1 MB</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ============================ 03 gists ============================ -->
			<section class="sect" data-sect>
				<p class="sect-label"><span class="node"></span>03 · gists</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">Reverse-engineer<br />once. Reuse forever.</h2>
						<p>
							A gist is a plain Python file repld reloads the moment you change it. Claude works out
							a site's private API once and writes the client. Import it forever. Link it across
							projects, or expose it as an MCP tool.
						</p>
					</div>
					<div class="pane wide" data-reveal>
						<p class="pane-title accent">↪ repld gist list</p>
						<pre
							class="gistlist">local (./gists):
  <span class="b">crm</span>          CRM(tab) <span class="dim">[async]</span>     <span class="dim">contacts, deals, pipeline</span>
  <span class="b">gmail</span>        Gmail()              <span class="dim">read, search, send</span>
  <span class="b">linkedin</span>     LI(tab, csrf) <span class="dim">[async]</span> <span class="dim">people + company search</span>
  <span class="b">stripe</span>       Stripe()             <span class="dim">invoices, subscriptions</span>
  <span class="b">acme</span>         Acme(tab) <span class="dim">[async]</span>    <span class="dim">company lookup, financials</span>
  <span class="b">shopify_sd</span>   SD(tab) <span class="dim">[async]</span>      <span class="dim">search &amp; discovery admin</span>
linked (from other projects):
  <span class="b">emulator</span>     Device() <span class="dim">[async]</span>     <span class="dim">android driver — adb + CDP</span></pre>
					</div>
				</div>
			</section>

			<!-- ============================ 04 controls ============================ -->
			<section class="sect" data-sect>
				<p class="sect-label"><span class="node"></span>04 · controls</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">See what your<br />app is doing.</h2>
						<p>
							Expose your app's own actions as a typed API. Claude runs them and watches every stage
							land, so when a pipeline breaks you see which stage failed the moment it fails, not an
							hour later in the logs.
						</p>
					</div>
					<div class="code-stack" data-reveal>
						<div class="session-card">
							<div class="sc-bar"><span class="sc-dot"></span>pipeline · live</div>
							<div class="sc-body sc-timeline">
								<div class="sc-stage">
									<span class="t">09:25:34</span><span class="k">controls</span><span class="v"
										>thread.send → 201</span
									>
								</div>
								<div class="sc-stage">
									<span class="t">09:25:37</span><span class="k">ai</span><span class="v"
										>classify: reply (0.92)</span
									>
								</div>
								<div class="sc-stage err">
									<span class="t">09:25:38</span><span class="k">error</span><span class="v"
										>API 400 <span class="note">← exactly where it broke</span></span
									>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ============================ 05 background ============================ -->
			<section class="sect" id="sect-channel" data-sect>
				<p class="sect-label"><span class="node"></span>05 · background</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">It keeps working<br />in the background.</h2>
						<p>
							Long jobs, watchers, webhooks and timers all run in the background and ping you when
							something happens. Claude starts a task and moves on; the result lands in the
							conversation when it's ready.
						</p>
					</div>
					<div class="code-stack" data-reveal>
						<div class="session-card">
							<div class="sc-bar"><span class="sc-dot"></span>background</div>
							<div class="sc-body">
								<div class="sc-line sc-you">
									<span class="pr">you ❯</span><span class="sc-say"
										>"scan the watchlist, ping me when it's done"</span
									>
								</div>
								<div class="sc-line sc-claude">
									<span class="pr">claude ❯</span><span class="sc-act"
										>defer(acme.scan(watchlist), "account scan")</span
									>
								</div>
								<div class="sc-line sc-out">
									⤷ task a91f · <span class="hl">running in the background</span>
								</div>
							</div>
						</div>
						<div class="toast" id="toast">
							<span class="zap">⚡ channel</span> · every · watch_inbox — "3 new — Re: term sheet"
						</div>
						<div class="toast toast-2" id="toast2">
							<span class="zap">⚡ channel</span> · task_done · account scan — 142 rows · 38s
						</div>
					</div>
				</div>
			</section>

			<!-- ============================ 06 progression ============================ -->
			<section class="sect" data-sect>
				<p class="sect-label"><span class="node"></span>06 · the progression</p>
				<div class="sect-grid">
					<div class="sect-copy">
						<h2 class="display">Every tool<br />starts as a<br />conversation.</h2>
						<p>
							Do it by hand first. By the third repeat the steps are obvious, and you pull them into
							a gist one phase at a time.
						</p>
						<p class="playbook-link">
							<a href={`${base}playbook`}
								>read the full playbook <Icon name="right-arrow" size="1em" /></a
							>
						</p>
					</div>
					<div class="progression" data-reveal>
						<div class="phase">
							<div class="phase-num">1</div>
							<div class="phase-body">
								<h3>Interactive</h3>
								<p>
									You and Claude work a task in repld. Poke at the browser, hit an API, inspect the
									result. No plan yet, just doing.
								</p>
							</div>
						</div>
						<div class="phase-line" aria-hidden="true"></div>
						<div class="phase">
							<div class="phase-num">2</div>
							<div class="phase-body">
								<h3>Scripted</h3>
								<p>
									You repeated it three times. Pull it into a gist, a plain Python file repld
									reloads on save. Same code, now importable.
								</p>
							</div>
						</div>
						<div class="phase-line" aria-hidden="true"></div>
						<div class="phase">
							<div class="phase-num">3</div>
							<div class="phase-body">
								<h3>Semi-auto</h3>
								<p>
									Wire a trigger: <code class="inline">@every</code>, a webhook, a spreadsheet
									column waiting for a human decision. The gist is the stage.
								</p>
							</div>
						</div>
						<div class="phase-line" aria-hidden="true"></div>
						<div class="phase">
							<div class="phase-num">4</div>
							<div class="phase-body">
								<h3>Production</h3>
								<p>
									The same gist now runs in FastAPI or Inngest: event-driven and durable. Nothing
									was thrown away.
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ============================ outro ============================ -->
			<section class="outro" data-sect>
				<h2 class="display">Give Claude<br />your apps.</h2>
				<div class="install big" data-reveal>
					<code><span class="dim">$</span> uv tool install repld-tool</code>
				</div>
				<div class="journey" data-reveal>
					<a href={`${base}quickstart`} class="journey-card">
						<span class="journey-label">Start here</span>
						<span class="journey-title">Quickstart</span>
						<span class="journey-desc">How to talk to Claude when repld is connected</span>
					</a>
					<span class="journey-arrow"><Icon name="right-arrow" size="1.2em" /></span>
					<a href={`${base}playbook`} class="journey-card">
						<span class="journey-label">Then read</span>
						<span class="journey-title">The Playbook</span>
						<span class="journey-desc">Prototype interactive, extract gists, wire triggers</span>
					</a>
					<span class="journey-arrow"><Icon name="right-arrow" size="1.2em" /></span>
					<a href={`${base}production`} class="journey-card">
						<span class="journey-label">When ready</span>
						<span class="journey-title">Production</span>
						<span class="journey-desc">Graduate gists to FastMCP or FastAPI</span>
					</a>
				</div>
				<p class="outro-links" data-reveal>
					<a href={`${base}docs/`}>read the docs <Icon name="right-arrow" size="1em" /></a>
				</p>
			</section>
		</main>

		<Footer tagline="built with repld, obviously" />

		<script>
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			import { SplitText } from 'gsap/SplitText';
			import Lenis from 'lenis';

			gsap.registerPlugin(ScrollTrigger, SplitText);

			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const finePointer = window.matchMedia('(pointer: fine)').matches;

			// Gate heading reveals on just the heading font, not every font. Read the real
			// hashed family off a heading so it survives Astro's per-build font hashing.
			const headingFontReady = (): Promise<unknown> => {
				const el = document.querySelector('.hero h1, .sect h2');
				if (!el) return document.fonts.ready;
				const cs = getComputedStyle(el);
				const family = cs.fontFamily.split(',')[0].trim();
				return document.fonts.load(`${cs.fontWeight || '800'} 1em ${family}`).catch(() => {});
			};

			// ---------- smooth scroll (Lenis ↔ ScrollTrigger sync) ----------
			if (!reduced) {
				const lenis = new Lenis({ autoRaf: false, lerp: 0.12 });
				lenis.on('scroll', ScrollTrigger.update);
				gsap.ticker.add((t) => lenis.raf(t * 1000));
				gsap.ticker.lagSmoothing(0);
			}

			// ---------- kernel boot preloader ----------
			const boot = document.getElementById('boot')!;
			const heroReady = () => {
				(window as any).__heroReady = true;
				window.dispatchEvent(new Event('repld:heroready'));
			};

			if (reduced || sessionStorage.getItem('repld-booted')) {
				boot.remove();
				heroReady();
			} else {
				gsap
					.timeline({
						onComplete: () => {
							boot.remove();
							ScrollTrigger.refresh();
						},
					})
					.to('.boot-line', { opacity: 1, duration: 0.16, stagger: 0.18, ease: 'none' })
					.to(boot, { yPercent: -100, duration: 0.65, ease: 'power4.inOut', delay: 0.35 })
					.add(heroReady, '-=0.5');
			}
			sessionStorage.setItem('repld-booted', '1');

			// ---------- hero entrance (masked headline lines) ----------
			function playHero() {
				if (reduced) return;
				headingFontReady().then(() => {
					const split = SplitText.create('.hero h1', { type: 'lines', mask: 'lines' });
					gsap.set('.hero h1', { visibility: 'visible' }); // lines masked offscreen — no flash
					gsap
						.timeline()
						.from('.kicker', { y: 18, autoAlpha: 0, duration: 0.5, ease: 'power3.out' })
						.from(
							split.lines,
							{
								yPercent: 115,
								duration: 0.9,
								stagger: 0.09,
								ease: 'power4.out',
								onComplete: () => split.revert(), // restore glow/text-shadow
							},
							0.05,
						)
						.from(
							['.sub', '.hero .install'],
							{ y: 24, autoAlpha: 0, duration: 0.7, stagger: 0.12, ease: 'power3.out' },
							0.45,
						)
						.from('.hero-term', { y: 30, autoAlpha: 0, duration: 0.8, ease: 'power3.out' }, 0.55);
				});
			}
			if ((window as any).__heroReady) playHero();
			else addEventListener('repld:heroready', playHero, { once: true });

			if (!reduced) {
				// ---------- section heading reveals: masked line slides ----------
				headingFontReady().then(() => {
					document.querySelectorAll<HTMLElement>('.sect h2, .outro h2').forEach((el) => {
						const split = SplitText.create(el, { type: 'lines', mask: 'lines' });
						gsap.set(el, { visibility: 'visible' });
						gsap.from(split.lines, {
							yPercent: 115,
							duration: 0.85,
							stagger: 0.09,
							ease: 'power4.out',
							scrollTrigger: { trigger: el, start: 'top 82%' },
							onComplete: () => split.revert(),
						});
					});
				});

				// ---------- section body reveals ----------
				document.querySelectorAll<HTMLElement>('[data-sect]').forEach((sect) => {
					const targets = sect.querySelectorAll(
						'.sect-label, .sect-copy p, [data-reveal], .outro-links',
					);
					if (!targets.length) return;
					gsap.from(targets, {
						y: 30,
						autoAlpha: 0,
						duration: 0.8,
						stagger: 0.12,
						ease: 'power3.out',
						scrollTrigger: { trigger: sect, start: 'top 72%' },
					});
				});

				// ---------- 02: pinned, scroll-told channel sequence ----------
				const mm = gsap.matchMedia();
				mm.add('(min-width: 901px)', () => {
					const tl = gsap.timeline({
						scrollTrigger: {
							trigger: '#sect-channel',
							start: 'center 55%',
							end: '+=110%',
							pin: true,
							scrub: 0.6,
						},
					});
					tl.from('#toast', { x: 90, autoAlpha: 0, duration: 0.35, ease: 'power2.out' }, 0.1)
						.from('#toast2', { x: 90, autoAlpha: 0, duration: 0.35, ease: 'power2.out' }, 0.55)
						.to({}, { duration: 0.2 }); // hold before unpin
				});
				mm.add('(max-width: 900px)', () => {
					gsap.from(['#toast', '#toast2'], {
						x: 60,
						autoAlpha: 0,
						duration: 0.6,
						stagger: 0.25,
						ease: 'back.out(1.6)',
						scrollTrigger: { trigger: '#toast', start: 'top 85%' },
					});
				});

				// ---------- the wire fills as you scroll ----------
				gsap.to('#wire-fill', {
					height: '100%',
					ease: 'none',
					scrollTrigger: { trigger: 'main', start: 'top top', end: 'bottom bottom', scrub: 0.4 },
				});
				document.querySelectorAll<HTMLElement>('.node').forEach((node) => {
					ScrollTrigger.create({
						trigger: node,
						start: 'top 60%',
						onEnter: () => node.classList.add('lit'),
						onLeaveBack: () => node.classList.remove('lit'),
					});
				});

				// ---------- micro-interactions (mouse only) ----------
				if (finePointer) {
					// magnetic pull on the copy button + outro link
					document.querySelectorAll<HTMLElement>('#copy-btn, .outro-links a').forEach((el) => {
						const xTo = gsap.quickTo(el, 'x', { duration: 0.4, ease: 'power3' });
						const yTo = gsap.quickTo(el, 'y', { duration: 0.4, ease: 'power3' });
						el.addEventListener('pointermove', (e) => {
							const r = el.getBoundingClientRect();
							xTo((e.clientX - (r.left + r.width / 2)) * 0.45);
							yTo((e.clientY - (r.top + r.height / 2)) * 0.45);
						});
						el.addEventListener('pointerleave', () => {
							xTo(0);
							yTo(0);
						});
					});

					// progression phases light up on scroll
					document.querySelectorAll<HTMLElement>('.phase').forEach((phase) => {
						ScrollTrigger.create({
							trigger: phase,
							start: 'top 70%',
							onEnter: () => phase.classList.add('lit'),
							onLeaveBack: () => phase.classList.remove('lit'),
						});
					});
				}
			}

			// ---------- copy button ----------
			const btn = document.getElementById('copy-btn');
			btn?.addEventListener('click', async () => {
				await navigator.clipboard.writeText('uv tool install repld-tool');
				btn.textContent = 'copied';
				setTimeout(() => (btn.textContent = 'copy'), 1500);
			});
		</script>

		<style>
			/* wider shell for the landing — cascades into Nav + Footer */
			:global(:root) {
				--shell-w: 1180px;
			}

			/* ---------- shell ---------- */
			main {
				max-width: var(--shell-w);
				margin: 0 auto;
				padding: 0 24px;
			}
			.display {
				font-family: var(--font-display);
				font-weight: 800;
				color: var(--color-bright);
				letter-spacing: -0.02em;
				line-height: 1.02;
			}
			.b {
				color: var(--color-bright);
			}
			code.inline {
				color: var(--color-accent);
				background: rgb(60 232 130 / 0.07);
				border: 1px solid rgb(60 232 130 / 0.18);
				border-radius: 4px;
				padding: 0 5px;
				font-size: 0.92em;
			}

			/* ---------- boot preloader ---------- */
			#boot {
				display: none; /* JS-on only — html.js flips it */
				position: fixed;
				inset: 0;
				z-index: 40;
				background: var(--color-ink);
				align-items: center;
				justify-content: center;
			}
			:global(html.js) #boot {
				display: flex;
			}
			.boot-line {
				opacity: 0;
				font-size: 13.5px;
				color: var(--color-muted);
				letter-spacing: 0.04em;
				line-height: 2.1;
			}
			.boot-ok {
				color: var(--color-accent);
			}

			/* ---------- wire ---------- */
			.wire {
				position: fixed;
				left: max(12px, calc((100vw - var(--shell-w)) / 2 - 48px));
				top: 0;
				bottom: 0;
				width: 1px;
				background: rgb(28 36 47 / 0.8);
				z-index: 1;
			}
			.wire-fill {
				width: 100%;
				height: 0;
				background: linear-gradient(to bottom, transparent, var(--color-accent));
				box-shadow: 0 0 12px rgb(60 232 130 / 0.5);
			}
			@media (max-width: 1320px) {
				.wire {
					display: none;
				}
			}

			/* ---------- outro links (shared nav/footer live in components) ---------- */
			.outro-links a {
				color: var(--color-muted);
				text-decoration: none;
				font-size: 15px;
				letter-spacing: 0.04em;
				background: linear-gradient(var(--color-accent), var(--color-accent)) no-repeat left
					bottom / 0% 1px;
				transition:
					color 0.18s,
					background-size 0.25s;
				padding-bottom: 2px;
				display: inline-block; /* magnetic transform needs a box */
			}
			.outro-links a:hover {
				color: var(--color-accent);
				background-size: 100% 1px;
			}

			/* ---------- hero ---------- */
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
				gap: 56px;
				align-items: center;
				padding: 72px 0 120px;
				position: relative;
			}
			.hero::before {
				content: '';
				position: absolute;
				top: -10%;
				right: -15%;
				width: 70%;
				height: 90%;
				background: radial-gradient(ellipse at center, rgb(60 232 130 / 0.07), transparent 65%);
				pointer-events: none;
			}
			.kicker {
				color: var(--color-accent);
				font-size: 12px;
				letter-spacing: 0.22em;
				text-transform: uppercase;
				margin-bottom: 22px;
			}
			.hero h1 {
				font-size: clamp(2.6rem, 5.4vw, 4.3rem);
				margin-bottom: 24px;
			}
			.hero h1 em {
				font-style: normal;
				color: var(--color-accent);
				text-shadow: 0 0 28px rgb(60 232 130 / 0.45);
			}
			.sub {
				color: var(--color-muted);
				max-width: 46ch;
				margin-bottom: 34px;
			}
			.install {
				display: inline-flex;
				align-items: center;
				gap: 14px;
				border: 1px solid var(--color-line);
				background: var(--color-panel);
				border-radius: 8px;
				padding: 12px 16px;
			}
			.install code {
				font-size: 14px;
				color: var(--color-bright);
			}
			.install.big {
				padding: 18px 26px;
			}
			.install.big code {
				font-size: clamp(14px, 2.6vw, 19px);
			}
			.install button {
				font-family: var(--font-mono);
				font-size: 12px;
				letter-spacing: 0.08em;
				color: var(--color-accent);
				background: rgb(60 232 130 / 0.08);
				border: 1px solid rgb(60 232 130 / 0.3);
				border-radius: 5px;
				padding: 4px 10px;
				cursor: pointer;
				transition: background 0.15s;
			}
			.install button:hover {
				background: rgb(60 232 130 / 0.18);
			}

			/* ---------- sections ---------- */
			.sect {
				padding: 96px 0;
				border-top: 1px solid rgb(28 36 47 / 0.55);
			}
			.sect-label {
				display: flex;
				align-items: center;
				gap: 10px;
				color: var(--color-muted);
				font-size: 12px;
				letter-spacing: 0.2em;
				text-transform: uppercase;
				margin-bottom: 42px;
			}
			.node {
				width: 9px;
				height: 9px;
				border-radius: 50%;
				border: 1px solid var(--color-muted);
				transition: all 0.4s;
			}
			.node.lit {
				background: var(--color-accent);
				border-color: var(--color-accent);
				box-shadow: 0 0 14px rgb(60 232 130 / 0.7);
			}
			.sect-grid {
				display: grid;
				grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
				gap: 56px;
				align-items: start;
			}
			.sect h2 {
				font-size: clamp(1.9rem, 3.6vw, 2.9rem);
				margin-bottom: 20px;
			}
			.sect-copy p {
				color: var(--color-muted);
				max-width: 44ch;
			}

			/* panes */
			.panes {
				display: grid;
				grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
				gap: 16px;
			}
			.pane {
				background: var(--color-panel-2);
				border: 1px solid var(--color-line);
				border-radius: 10px;
				padding: 16px 18px;
				overflow-x: auto;
			}
			.pane-title {
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				margin-bottom: 12px;
			}
			.pane-title.accent {
				color: var(--color-accent);
			}
			.pane-title.amber {
				color: var(--color-amber);
			}
			.pane pre {
				font-size: 13px;
				line-height: 1.85;
				color: var(--color-fg);
			}
			.gistlist {
				white-space: pre;
			}

			/* code cards */
			.code-stack {
				position: relative;
			}
			.code-card {
				border: 1px solid var(--color-line);
				border-radius: 10px;
				overflow: hidden;
				background: var(--color-panel-2);
			}
			.code-card :global(pre) {
				padding: 20px 22px;
				font-size: 13.5px;
				line-height: 1.8;
				background: transparent !important;
				overflow-x: auto;
			}

			/* ---------- session card (you ↔ claude scenes) ---------- */
			.session-card {
				border: 1px solid var(--color-line);
				border-radius: 10px;
				overflow: hidden;
				background: var(--color-panel-2);
				box-shadow:
					0 0 0 1px rgb(0 0 0 / 0.4),
					0 22px 60px -30px rgb(60 232 130 / 0.25),
					0 8px 30px rgb(0 0 0 / 0.5);
			}
			.sc-bar {
				display: flex;
				align-items: center;
				gap: 9px;
				padding: 9px 15px;
				border-bottom: 1px solid var(--color-line);
				background: var(--color-panel);
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--color-muted);
			}
			.sc-dot {
				width: 7px;
				height: 7px;
				border-radius: 50%;
				background: var(--color-accent);
				box-shadow: 0 0 9px rgb(60 232 130 / 0.7);
			}
			.sc-body {
				padding: 17px 18px;
				font-size: 13.5px;
				line-height: 1.95;
				overflow-x: auto;
			}
			.sc-line {
				white-space: pre-wrap;
				word-break: break-word;
			}
			.sc-you .pr {
				color: var(--color-amber);
				font-weight: 700;
				margin-right: 8px;
			}
			.sc-claude .pr {
				color: var(--color-accent);
				font-weight: 700;
				margin-right: 8px;
			}
			.sc-say {
				color: var(--color-bright);
			}
			.sc-act {
				color: var(--color-fg);
			}
			.sc-out {
				color: var(--color-muted);
				padding-left: 1.8em;
			}
			.sc-out .hl {
				color: var(--color-accent);
			}
			.sc-gap {
				height: 11px;
			}
			/* controls pipeline timeline */
			.sc-timeline {
				line-height: 2.3;
			}
			.sc-stage {
				display: grid;
				grid-template-columns: auto 76px 1fr;
				gap: 16px;
				white-space: pre;
			}
			.sc-stage .t {
				color: var(--color-muted);
			}
			.sc-stage .k {
				color: var(--color-accent);
			}
			.sc-stage.err .k {
				color: #ff6b6b;
			}
			.sc-stage .v {
				color: var(--color-fg);
			}
			.sc-stage .v .note {
				color: var(--color-muted);
			}
			.toast {
				position: absolute;
				right: -14px;
				bottom: -26px;
				border: 1px solid rgb(255 180 84 / 0.4);
				background: rgb(20 17 12 / 0.96);
				border-radius: 8px;
				padding: 10px 16px;
				font-size: 13px;
				box-shadow: 0 12px 40px rgb(0 0 0 / 0.5);
			}
			.toast-2 {
				right: 22px;
				bottom: 28px;
				border-color: rgb(60 232 130 / 0.4);
				background: rgb(12 20 15 / 0.96);
			}
			.toast-2 .zap {
				color: var(--color-accent);
			}
			.zap {
				color: var(--color-amber);
				font-weight: 700;
			}

			/* progression */
			.progression {
				display: flex;
				flex-direction: column;
				gap: 0;
			}
			.phase {
				display: flex;
				gap: 18px;
				align-items: flex-start;
			}
			.phase-num {
				flex-shrink: 0;
				width: 34px;
				height: 34px;
				border-radius: 50%;
				border: 1px solid var(--color-line);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 13px;
				font-weight: 700;
				color: var(--color-muted);
				margin-top: 2px;
				transition: all 0.4s;
			}
			.phase:hover .phase-num,
			.phase.lit .phase-num {
				background: var(--color-accent);
				border-color: var(--color-accent);
				color: var(--color-ink);
				box-shadow: 0 0 14px rgb(60 232 130 / 0.5);
			}
			.phase-body h3 {
				font-family: var(--font-display);
				font-weight: 700;
				color: var(--color-bright);
				font-size: 17px;
				margin-bottom: 6px;
			}
			.phase-body p {
				color: var(--color-muted);
				font-size: 13.5px;
				max-width: 42ch;
			}
			.phase-line {
				width: 1px;
				height: 28px;
				margin-left: 17px;
				background: var(--color-line);
			}
			.playbook-link {
				margin-top: 20px;
			}
			.playbook-link a {
				color: var(--color-accent);
				text-decoration: none;
				font-size: 14px;
				background: linear-gradient(var(--color-accent), var(--color-accent)) no-repeat left
					bottom / 0% 1px;
				transition: background-size 0.25s;
				padding-bottom: 2px;
			}
			.playbook-link a:hover {
				background-size: 100% 1px;
			}

			/* outro */
			.outro {
				text-align: center;
				padding: 140px 0 150px;
				border-top: 1px solid rgb(28 36 47 / 0.55);
			}
			.outro h2 {
				font-size: clamp(2.4rem, 5vw, 4rem);
				margin-bottom: 40px;
			}
			.journey {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 16px;
				margin-top: 48px;
			}
			.journey-card {
				border: 1px solid var(--color-line);
				background: var(--color-panel);
				border-radius: 10px;
				padding: 20px 22px;
				text-decoration: none;
				text-align: left;
				max-width: 220px;
				display: flex;
				flex-direction: column;
				gap: 6px;
				transition:
					border-color 0.2s,
					transform 0.2s;
			}
			.journey-card:hover {
				border-color: rgb(60 232 130 / 0.4);
				transform: translateY(-3px);
			}
			.journey-label {
				font-size: 10px;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--color-accent);
			}
			.journey-title {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 16px;
				color: var(--color-bright);
			}
			.journey-desc {
				font-size: 12.5px;
				color: var(--color-muted);
				line-height: 1.5;
			}
			.journey-arrow {
				color: var(--color-muted);
				opacity: 0.4;
				display: flex;
				align-items: center;
			}
			.journey-arrow :global(svg) {
				width: 1.2em;
				height: 1.2em;
			}
			.outro-links {
				margin-top: 28px;
			}

			/* ---------- mobile ---------- */
			@media (max-width: 900px) {
				.journey {
					flex-direction: column;
					gap: 12px;
				}
				.journey-card {
					max-width: 100%;
					width: 100%;
				}
				.journey-arrow {
					transform: rotate(90deg);
				}
				.hero {
					grid-template-columns: minmax(0, 1fr);
					gap: 44px;
					padding: 40px 0 80px;
				}
				.sect {
					padding: 64px 0;
				}
				.sect-grid {
					grid-template-columns: minmax(0, 1fr);
					gap: 32px;
				}
				.toast {
					right: 0;
					bottom: -34px;
				}
				.toast-2 {
					right: 10px;
					bottom: 24px;
				}
			}
			@media (max-width: 560px) {
				.panes {
					grid-template-columns: minmax(0, 1fr);
				}
				.code-card :global(pre) {
					font-size: 12px;
					padding: 16px 16px;
				}
				.pane pre {
					font-size: 12px;
				}
				.sc-body {
					font-size: 12px;
				}
				.sc-stage {
					grid-template-columns: auto 1fr;
					gap: 6px 12px;
				}
				.sc-stage .v {
					grid-column: 1 / -1;
				}
				.footer {
					flex-direction: column;
				}
				.hero .install {
					width: 100%;
					justify-content: space-between;
				}
				.install.big {
					justify-content: center;
				}
			}
		</style>
	</body>
</html>
