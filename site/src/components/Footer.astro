---
interface Props {
	tagline?: string;
}

const { tagline } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="footer">
	<span class="wordmark">repld<span class="cursor"></span></span>
	<nav class="footer-links">
		<a href={`${base}docs/`}>docs</a>
		<a href="https://pypi.org/project/repld-tool/">pypi</a>
		<a href="https://github.com/angelsen/repld">github</a>
	</nav>
	{tagline && <span class="tagline">{tagline}</span>}
</footer>

<style>
	.footer {
		max-width: var(--shell-w);
		margin: 0 auto;
		padding: 26px 24px 34px;
		border-top: var(--rule);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 18px;
		font-size: 13px;
	}
	.wordmark {
		font-weight: 700;
		font-size: 15px;
		color: var(--color-bright);
	}
	.cursor {
		display: inline-block;
		width: 8px;
		height: 1em;
		margin-left: 2px;
		vertical-align: text-bottom;
		background: var(--color-accent);
		animation: blink 1.06s steps(1) infinite;
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}
	.footer-links {
		display: flex;
		gap: 22px;
	}
	.footer-links a {
		color: var(--color-muted);
		text-decoration: none;
		font-size: 13.5px;
		letter-spacing: 0.04em;
		background: linear-gradient(var(--color-accent), var(--color-accent)) no-repeat left bottom / 0%
			1px;
		transition:
			color 0.18s,
			background-size 0.25s;
		padding-bottom: 2px;
	}
	.footer-links a:hover {
		color: var(--color-accent);
		background-size: 100% 1px;
	}
	.tagline {
		color: var(--color-muted);
	}
	@media (max-width: 560px) {
		.footer {
			flex-direction: column;
		}
	}
</style>
