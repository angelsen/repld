---
import BaseHead from '../components/BaseHead.astro';
import { type Image } from '../components/SEO.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	active?: 'quickstart' | 'playbook' | 'controls' | 'production' | 'docs';
	image?: Image;
	pageType?: 'website' | 'article';
}

const { title, description, active, image, pageType } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} pageType={pageType} />
	</head>
	<body class="editorial">
		<Nav active={active} />
		<main>
			<slot />
		</main>
		<Footer />

		<script>
			import { initReveal } from '../scripts/reveal';
			initReveal();
		</script>
	</body>
</html>
